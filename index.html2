        }

        /* Simulador */
        .simulador-section {
            padding: 80px 20px;
        }

        .calculadora-box {
            background: var(--white);
            max-width: 600px;
            margin: 0 auto;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 1rem;
        }

        .btn-calc {
            width: 100%;
            background-color: var(--dark-color);
            color: var(--white);
            padding: 14px;
            border: none;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: background 0.3s;
        }

        .btn-calc:hover {
            background-color: var(--primary-color);
        }

        .resultado {
            margin-top: 30px;
            padding: 20px;
            background-color: #e8f5e9;
            border-radius: 5px;
            border: 1px solid #c8e6c9;
        }

        .hidden { display: none; }

        /* Contato */
        .contato-section {
            padding: 80px 20px;
        }

        .form-contato {
            max-width: 600px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .form-contato input, .form-contato textarea {
            padding: 14px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 1rem;
        }

        /* Rodapé */
        footer {
            background-color: #111;
            color: #999;
            padding: 40px 20px;
            margin-top: 60px;
        }

        .footer-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .sociais a {
            color: #999;
            font-size: 1.5rem;
            margin-left: 15px;
            transition: color 0.3s;
        }

        .sociais a:hover {
            color: var(--primary-light);
        }

        /* Responsividade Mobile */
        @media (max-width: 768px) {
            .nav-links {
                display: none;
                flex-direction: column;
                width: 100%;
                position: absolute;
                top: 70px;
                left: 0;
                background-color: var(--white);
                box-shadow: 0 10px 10px rgba(0,0,0,0.1);
                padding: 20px;
            }
            
            .nav-links.active {
                display: flex;
            }

            .menu-toggle {
                display: block;
            }

            .hero-content h1 {
                font-size: 2.2rem;
            }
        }
    </style>
</head>
<body>

    <!-- Cabeçalho e Menu -->
    <header>
        <div class="container navbar">
            <div class="logo">
                <i class="fa-solid fa-leaf"></i> <span>AgroPortal</span>
            </div>
            <nav>
                <ul class="nav-links">
                    <li><a href="#home">Início</a></li>
                    <li><a href="#cotacoes">Cotações</a></li>
                    <li><a href="#tecnologia">Tecnologia</a></li>
                    <li><a href="#simulador">Simulador</a></li>
                    <li><a href="#contato">Contato</a></li>
                </ul>
            </nav>
            <div class="menu-toggle" id="mobile-menu">
                <i class="fa-solid fa-bars"></i>
            </div>
        </div>
    </header>

    <!-- Banner Principal -->
    <section id="home" class="hero">
        <div class="container hero-content">
            <h1>O Futuro do Agronegócio é Tecnológico</h1>
            <p>Conectando o produtor rural às principais tendências de mercado, inovações no campo e ferramentas de alta produtividade.</p>
            <a href="#simulador" class="btn">Testar Simulador</a>
        </div>
    </section><!DOCTYPE html>
