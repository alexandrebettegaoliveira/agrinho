        .resultado {
            margin-top: 30px;
            padding: 20px;
            background-color: #e8f5e9;
            border-radius: 5px;
            border: 1px solid #c8e6c9;
        }

        .hidden { display: none; }

        /* Contato */
        .contato-section {
            padding: 80px 20px;
        }

        .form-contato {
            max-width: 600px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .form-contato input, .form-contato textarea {
            padding: 14px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 1rem;
        }

        /* Rodapé */
        footer {
            background-color: #111;
            color: #999;
            padding: 40px 20px;
            margin-top: 60px;
        }

        .footer-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .sociais a {
            color: #999;
            font-size: 1.5rem;
            margin-left: 15px;
            transition: color 0.3s;
        }

        .sociais a:hover {
            color: var(--primary-light);
        }

        /* Responsividade Mobile */
        @media (max-width: 768px) {
            .nav-links {
                display: none;
                flex-direction: column;
                width: 100%;
                position: absolute;
                top: 70px;
                left: 0;
                background-color: var(--white);
                box-shadow: 0 10px 10px rgba(0,0,0,0.1);
                padding: 20px;
            }
            
            .nav-links.active {
                display: flex;
            }

            .menu-toggle {
                display: block;
            }

            .hero-content h1 {
                font-size: 2.2rem;
            }
        }
    </style>
