<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgroTech - O Futuro do Campo</title>
    
    <style>
        /* ==================== CSS (ESTILO) ==================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f4f7f5;
            color: #333;
            line-height: 1.6;
        }

        header {
            background-color: #1b4332;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        header .logo {
            font-size: 24px;
            font-weight: bold;
        }

        header .logo span {
            color: #52b788;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            font-weight: 500;
        }

        nav a:hover {
            color: #52b788;
        }

        .hero {
            background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), 
                        url('https://unsplash.com') no-repeat center center/cover;
            height: 60vh;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 42px;
            margin-bottom: 20px;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 30px;
        }

        .btn {
            background-color: #52b788;
            color: white;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
        }

        .btn:hover {
            background-color: #40916c;
        }

        .container {
            padding: 60px 10%;
            text-align: center;
        }

        .features {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            background-color: #e9f5ed;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            flex: 1;
        }

        .card h3 {
            color: #1b4332;
            margin-bottom: 15px;
        }

        footer {
            background-color: #1b4332;
            color: white;
            text-align: center;
            padding: 20px;
            font-size: 14px;
        }

        /* ♿ BOTÃO DE ACESSIBILIDADE FIXADO NO CANTO INFERIOR DIREITO */
        .btn-acessibilidade {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 60px;
            height: 60px;
            background-color: #028090;
            color: white;
            border: none;
            border-radius: 50%;
            font-size: 28px;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s;
        }

        .btn-acessibilidade:hover {
            transform: scale(1.1);
        }

        /* 🌓 CLASSE DE ALTO CONTRASTE ATIVADA PELO JAVASCRIPT */
        body.alto-contraste {
            background-color: #000 !important;
            color: #fff !important;
        }

        body.alto-contraste header, 
        body.alto-contraste footer,
        body.alto-contraste .card {
            background-color: #111 !important;
            border: 1px solid #fff;
            color: #fff !important;
        }

        body.alto-contraste nav a,
        body.alto-contraste .card h3 {
            color: #ff0 !important;
        }

        body.alto-contraste .btn {
            background-color: #ff0 !important;
            color: #000 !important;
        }
    </style>
</head>
<body>

    <!-- ==================== CONTEÚDO (HTML) ==================== -->
    <header>
        <div class="logo">Agro<span>Tech</span></div>
        <nav>
            <a href="#inicio">Início</a>
            <a href="#sobre">Sobre</a>
            <a href="#tecnologia">Tecnologia</a>
        </nav>
    </header>

    <section id="inicio" class="hero">
        <div class="hero-content">
            <h1>Inovação e Sustentabilidade no Campo</h1>
            <p>Conectando tecnologia de ponta com a produção agrícola.</p>
            <a href="#tecnologia" class="btn">Conhecer Soluções</a>
        </div>
    </section>

    <section id="sobre" class="container">
        <h2>Quem Somos</h2>
        <p>Somos líderes na transformação digital do agronegócio, desenvolvendo soluções inteligentes que aumentam a produtividade da lavoura.</p>
    </section>

    <section id="tecnologia" class="features container">
        <div class="card">
            <h3>Drones e Mapeamento</h3>
            <p>Monitoramento aéreo detalhado da saúde da lavoura em tempo real.</p>
        </div>
        <div class="card">
            <h3>Gestão de Solo</h3>
            <p>Análise de dados climáticos e sensores para irrigação precisa.</p>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 AgroTech. Todos os direitos reservados.</p>
    </footer>

    <!-- O BOTÃO FLUTUANTE -->
    <button id="btnAcessibilidade" class="btn-acessibilidade" aria-label="Ativar Alto Contraste">♿</button>

    <!-- ==================== LÓGICA (JAVASCRIPT) ==================== -->
    <script>
        const btnAcessibilidade = document.getElementById('btnAcessibilidade');

        btnAcessibilidade.addEventListener('click', () => {
            // Liga e desliga a classe de alto contraste ao clicar no botão
            document.body.classList.toggle('alto-contraste');
        });
    </script>
</body>
<!-- ==================== SEÇÃO: SERVIÇOS (CONTINUAÇÃO) ==================== -->
<section class="services-section">
    <div class="services-container">
        <!-- Card 3 -->
        <div class="service-card">
            <h3>Automação de Maquinário</h3>
            <p>Integração de sistemas inteligentes para otimizar o plantio e a colheita automotiva.</p>
        </div>
        <!-- Card 4 -->
        <div class="service-card">
            <h3>Dashboards de Produtividade</h3>
            <p>Relatórios em tempo real para tomada de decisões financeiras e operacionais rápidas.</p>
        </div>
    </div>
</section>

<!-- ==================== SEÇÃO: RESULTADOS (NÚMEROS) ==================== -->
<section class="results-section">
    <div class="results-container">
        <div class="result-item">
            <h2 class="counter" data-target="35">+0</h2>
            <p>Eficiência no uso de água e insumos</p>
        </div>
        <div class="result-item">
            <h2 class="counter" data-target="24">0</h2>
            <p>Horas de monitoramento contínuo</p>
        </div>
        <div class="result-item">
            <h2 class="counter" data-target="20">-0</h2>
            <p>Redução nos custos operacionais</p>
        </div>
    </div>
</section>
<!-- ==================== RODAPÉ (FOOTER) ==================== -->
<footer class="main-footer">
    <div class="footer-container">
        <div class="footer-brand">
            <h2>AgroTech</h2>
            <p>Transformando o futuro do agronegócio com inovação e sustentabilidade.</p>
        </div>
        <div class="footer-links">
            <h4>Navegação</h4>
            <ul>
                <li><a href="#">Início</a></li>
                <li><a href="#">Sobre</a></li>
                <li><a href="#">Tecnologia</a></li>
                <li><a href="#">Contato</a></li>
            </ul>
        </div>
        <div class="footer-contact">
            <h4>Contato</h4>
            <p>E-mail: contato@agrotech.com</p>
            <p>Telefone: (11) 99999-9999</p>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 AgroTech. Todos os direitos reservados.</p>
    </div>
</footer>

<!-- ==================== ESTILOS CSS ==================== -->
<style>
    /* Reset e Variáveis de Cores (Alinhar com o seu design) */
    :root {
        --green-dark: #0f3025;     /* Tom verde do seu menu */
        --green-accent: #2ecc71;   /* Tom verde do seu botão */
        --bg-light: #f4f7f6;       /* Cor de fundo clara */
        --text-dark: #333333;
        --text-light: #ffffff;
    }

    /* Container de Serviços */
    .services-section {
        background-color: var(--bg-light);
        padding: 0 20px 60px 20px;
        display: flex;
        justify-content: center;
    }

    .services-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        width: 100%;
        max-width: 1200px;
    }

    .service-card {
        background: #ffffff;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    .service-card h3 {
        color: var(--green-dark);
        margin-bottom: 15px;
        font-size: 1.2rem;
    }

    .service-card p {
        color: #666;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    /* Seção de Resultados */
    .results-section {
        background-color: var(--green-dark);
        color: var(--text-light);
        padding: 80px 20px;
        text-align: center;
    }

    .results-container {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        max-width: 1200px;
        margin: 0 auto;
        gap: 40px;
    }

    .result-item h2 {
        font-size: 3rem;
        color: var(--green-accent);
        margin-bottom: 10px;
    }

    .result-item p {
        font-size: 1.1rem;
        opacity: 0.9;
    }

    /* Rodapé */
    .main-footer {
        background-color: #111;
        color: #bbb;
        padding: 60px 20px 20px 20px;
        font-size: 0.9rem;
    }

    .footer-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 40px;
        max-width: 1200px;
        margin: 0 auto;
        border-bottom: 1px solid #222;
        padding-bottom: 40px;
    }

    .footer-brand h2 {
        color: var(--text-light);
        margin-bottom: 15px;
    }

    .footer-links h4, .footer-contact h4 {
        color: var(--text-light);
        margin-bottom: 15px;
    }

    .footer-links ul {
        list-style: none;
        padding: 0;
    }

    .footer-links ul li {
        margin-bottom: 10px;
    }

    .footer-links ul li a {
        color: #bbb;
        text-decoration: none;
        transition: color 0.3s;
    }

    .footer-links ul li a:hover {
        color: var(--green-accent);
    }

    .footer-bottom {
        text-align: center;
        padding-top: 20px;
        font-size: 0.8rem;
    }
</style>

<!-- ==================== SCRIPT JAVASCRIPT ==================== -->
<script>
    // Efeito de contagem animada para a seção de resultados
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.counter');
        const speed = 50; // Quanto menor, mais rápida a animação

        counters.forEach(counter => {
            const updateCount = () => {
                const target = +counter.getAttribute('data-target');
                // Remove caracteres especiais para fazer o cálculo matemático puro
                const currentText = counter.innerText.replace('+', '').replace('-', '');
                const count = +currentText;

                const increment = target / speed;

                if (count < target) {
                    const nextValue = Math.ceil(count + increment);
                    // Recoloca os sinais visuais de positivo ou negativo conforme o alvo
                    if (counter.getAttribute('data-target') == "35") {
                        counter.innerText = `+${nextValue}%`;
                    } else if (counter.getAttribute('data-target') == "20") {
                        counter.innerText = `-${nextValue}%`;
                    } else {
                        counter.innerText = nextValue;
                    }
                    setTimeout(updateCount, 20);
                } else {
                    // Garante que o número final exato seja exibido com os sufixos corretos
                    if (target === 35) counter.innerText = "+35%";
                    else if (target === 20) counter.innerText = "-20%";
                    else counter.innerText = "24h";
                }
            };

            updateCount();
        });
    });
</script>
</html>
