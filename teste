<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Jogo de Carro com JavaScript</title>
    
    <!-- ESTILO (CSS): Cuida das cores e posições na tela -->
    <style>
        body {
            margin: 0;
            background-color: #1a1a1a;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: 'Arial', sans-serif;
            color: #fff;
            overflow: hidden;
        }
        #tela-jogo {
            border: 4px solid #fff;
            background-color: #333;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }
        #placar {
            position: absolute;
            top: 20px;
            font-size: 28px;
            font-weight: bold;
            text-shadow: 2px 2px #000;
        }
    </style>
</head>
<body>

    <div id="placar">Pontos: 0</div>
    <canvas id="tela-jogo" width="400" height="500"></canvas>

    <!-- LÓGICA (JavaScript): Controla as regras, movimentos e o jogo -->
    <script>
        // 1. Configurações Iniciais da Tela
        const canvas = document.getElementById("tela-jogo");
        const ctx = canvas.getContext("2d");
        const elementoPlacar = document.getElementById("placar");

        let pontos = 0;
        let fimDeJogo = false;

        // 2. Objeto do Jogador (Carro Azul)
        const jogador = {
            x: 175,
            y: 410,
            largura: 50,
            altura: 80,
            velocidade: 8,
            desenhar() {
                ctx.fillStyle = "#00aaff"; // Azul
                ctx.fillRect(this.x, this.y, this.largura, this.altura);
                
                // Detalhes do carro (Rodas)
                ctx.fillStyle = "#000";
                ctx.fillRect(this.x - 5, this.y + 10, 5, 20);
                ctx.fillRect(this.x + this.largura, this.y + 10, 5, 20);
                ctx.fillRect(this.x - 5, this.y + 50, 5, 20);
                ctx.fillRect(this.x + this.largura, this.y + 50, 5, 20);
            }
        };

        // 3. Objeto do Obstáculo (Carro Vermelho)
        const obstaculo = {
            x: Math.random() * (canvas.width - 50),
            y: -80,
            largura: 50,
            altura: 80,
            velocidade: 6,
            desenhar() {
                ctx.fillStyle = "#ff4444"; // Vermelho
                ctx.fillRect(this.x, this.y, this.largura, this.altura);
                
                // Detalhes do obstáculo (Rodas)
                ctx.fillStyle = "#000";
                ctx.fillRect(this.x - 5, this.y + 10, 5, 20);
                ctx.fillRect(this.x + this.largura, this.y + 10, 5, 20);
                ctx.fillRect(this.x - 5, this.y + 50, 5, 20);
                ctx.fillRect(this.x + this.largura, this.y + 50, 5, 20);
            }
        };

        // 4. Controle do Teclado (Eventos JavaScript)
        const teclas = { SetaEsquerda: false, SetaDireita: false };

        document.addEventListener("keydown", (evento) => {
            if (evento.key === "ArrowLeft") teclas.SetaEsquerda = true;
            if (evento.key === "ArrowRight") teclas.SetaDireita = true;
        });

        document.addEventListener("keyup", (evento) => {
            if (evento.key === "ArrowLeft") teclas.SetaEsquerda = false;
            if (evento.key === "ArrowRight") teclas.SetaDireita = false;
        });

        // 5. Função de Colisão (Matemática no JavaScript)
        function verificarColisao(obj1, obj2) {
            return (
                obj1.x < obj2.x + obj2.largura &&
                obj1.x + obj1.largura > obj2.x &&
                obj1.y < obj2.y + obj2.altura &&
                obj1.y + obj1.altura > obj2.y
            );
        }

        // 6. Loop Principal do Jogo (Atualiza a tela 60 vezes por segundo)
        function atualizarJogo() {
            if (fimDeJogo) return;

            // Limpa a tela anterior
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Desenha a sinalização da pista
            ctx.strokeStyle = "#fff";
            ctx.lineWidth = 6;
            ctx.setLineDash([20, 20]);
            ctx.beginPath();
            ctx.moveTo(canvas.width / 2, 0);
            ctx.lineTo(canvas.width / 2, canvas.height);
            ctx.stroke();

            // Movimenta o Jogador
            if (teclas.SetaEsquerda && jogador.x > 0) {
                jogador.x -= jogador.velocidade;
            }
            if (teclas.SetaDireita && jogador.x < canvas.width - jogador.largura) {
                jogador.x += jogador.velocidade;
            }

            // Movimenta o Obstáculo
            obstaculo.y += obstaculo.velocidade;

            // Se o obstáculo desviar e passar da tela
            if (obstaculo.y > canvas.height) {
                obstaculo.y = -80;
                obstaculo.x = Math.random() * (canvas.width - obstaculo.largura);
                pontos++;
                obstaculo.velocidade += 0.4; // Aumenta a dificuldade
                elementoPlacar.innerText = "Pontos: " + pontos;
            }

            // Desenha os elementos na tela
            jogador.desenhar();
            obstaculo.desenhar();

            // Checa se bateu
            if (verificarColisao(jogador, obstaculo)) {
                fimDeJogo = true;
                
                // Tela de Game Over
                ctx.fillStyle = "rgba(0, 0, 0, 0.8)";
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                
                ctx.fillStyle = "#ff4444";
                ctx.font = "bold 34px Arial";
                ctx.textAlign = "center";
                ctx.fillText("FIM DE JOGO!", canvas.width / 2, canvas.height / 2 - 20);
                
                ctx.fillStyle = "#fff";
                ctx.font = "18px Arial";
                ctx.fillText("Pressione F5 para reiniciar", canvas.width / 2, canvas.height / 2 + 30);
            }

            // Chama o próximo frame
            requestAnimationFrame(atualizarJogo);
        }

        // Inicia o ciclo do JavaScript
        atualizarJogo();
    </script>
</body>
</html>
