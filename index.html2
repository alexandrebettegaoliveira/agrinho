            gap: 15px;
        }

        .form-contato input, .form-contato textarea {
            padding: 14px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 1rem;
        }

        /* Rodapé */
        footer {
            background-color: #111;
            color: #999;
            padding: 40px 20px;
            margin-top: 60px;
        }

        .footer-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

