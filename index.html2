<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgroTech - O Futuro do Campo</title>
    
    <style>
        /* ==================== CSS (ESTILO) ==================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: #f4f7f5;
            color: #333;
            line-height: 1.6;
        }

        header {
            background-color: #1b4332;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        header .logo {
            font-size: 24px;
            font-weight: bold;
        }

        header .logo span {
            color: #52b788;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            font-weight: 500;
        }

        nav a:hover {
            color: #52b788;
        }

        /* Fundo em degradê verde/terra para funcionar 100% offline */
        .hero {
            background: linear-gradient(135deg, #1b4332 0%, #40916c 100%);
            height: 50vh;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 42px;
            margin-bottom: 20px;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 30px;
        }

        .btn {
            background-color: #52b788;
            color: white;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            display: inline-block;
            cursor: pointer;
            border: none;
        }

        .btn:hover {
            background-color: #40916c;
        }

        .container {
            padding: 60px 10%;
            text-align: center;
        }

        /* Grid moderno para as caixas de recursos */
        .features {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            background-color: #e9f5ed;
            flex-wrap: wrap;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            flex: 1;
            min-width: 250px;
            text-align: left;
        }

        .card h3 {
            color: #1b4332;
            margin-bottom: 15px;
        }

        /* Nova Tabela de Cotações */
        .tabela-mercado {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            background: white;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .tabela-mercado th, .tabela-mercado td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .tabela-mercado th {
            background-color: #1b4332;
            color: white;
        }

        /* Novo Simulador de Safra */
        .simulador-box {
            background: white;
            padding: 30px;
            border-radius: 8px;
            max-width: 500px;
            margin: 20px auto;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            text-align: left;
        }

        .campo-grupo {
            margin-bottom: 15px;
        }

        .campo-grupo label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
        }

        .campo-grupo input, .campo-grupo select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .resultado-painel {
            margin-top: 20px;
            padding: 15px;
            background-color: #d8f3dc;
            border-left: 5px solid #52b788;
            font-weight: bold;
            display: none;
        }

        footer {
            background-color: #1b4332;
            color: white;
            text-align: center;
            padding: 20px;
            font-size: 14px;
        }

        /* ♿ BOTÃO DE ACESSIBILIDADE FIXADO NO CANTO INFERIOR DIREITO */
        .btn-acessibilidade {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 60px;
            height: 60px;
            background-color: #028090;
            color: white;
            border: none;
            border-radius: 50%;
            font-size: 28px;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* 🌓 CLASSE DE ALTO CONTRASTE ATIVADA PELO JAVASCRIPT */
        body.alto-contraste {
            background-color: #000 !important;
            color: #fff !important;
        }

        body.alto-contraste header, 
        body.alto-contraste footer,
        body.alto-contraste .card,
        body.alto-contraste .simulador-box {
            background-color: #111 !important;
            border: 1px solid #fff;
            color: #fff !important;
        }

        body.alto-contraste nav a,
        body.alto-contraste .card h3 {
            color: #ff0 !important;
        }

        body.alto-contraste .btn {
            background-color: #ff0 !important;
            color: #000 !important;
        }
    </style>
</head>
<body>

    <!-- ==================== CONTEÚDO (HTML) ==================== -->
    <header>
        <div class="logo">Agro<span>Tech</span></div>
        <nav>
            <a href="#inicio">Início</a>
            <a href="#sobre">Sobre</a>
            <a href="#mercado">Mercado</a>
            <a href="#simulador">Simulador</a>
        </nav>
    </header>

    <section id="inicio" class="hero">
        <div class="hero-content">
            <h1>Inovação e Sustentabilidade no Campo</h1>
            <p>Conectando tecnologia de ponta com a produção agrícola de precisão.</p>
            <a href="#simulador" class="btn">Abrir Ferramentas</a>
        </div>
    </section>

    <section id="sobre" class="container">
        <h2>Quem Somos</h2>
        <p>Somos líderes na transformação digital do agronegócio, desenvolvendo soluções inteligentes que aumentam a produtividade e a saúde da lavoura.</p>
    </section>

    <section class="features container">
        <div class="card">
            <h3>Drones e Mapeamento</h3>
            <p>Monitoramento aéreo detalhado da saúde da lavoura em tempo real.</p>
        </div>
        <div class="card">
            <h3>Gestão de Solo</h3>
            <p>Análise automatizada de dados climáticos e sensores para irrigação precisa.</p>
        </div>
        <div class="card">
            <h3>Previsão Preditiva</h3>
            <p>Algoritmos avançados que calculam as melhores janelas climáticas para colheita.</p>
        </div>
    </section>

    <!-- NOVA SEÇÃO: COTAÇÕES DO MERCADO -->
    <section id="mercado" class="container">
        <h2>Painel de Commodities</h2>
        <p>Preços médios atuais praticados no mercado agrícola nacional.</p>
        <table class="tabela-mercado">
            <thead>
                <tr>
                    <th>Cultura</th>
                    <th>Preço Base</th>
                    <th>Tendência</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Soja (Saca 60kg)</td>
                    <td>R$ 138,50</td>
                    <td style="color: green; font-weight: bold;">Alta ▲</td>
                </tr>
                <tr>
                    <td>Milho (Saca 60kg)</td>
                    <td>R$ 62,10</td>
                    <td style="color: red; font-weight: bold;">Baixa ▼</td>
                </tr>
                <tr>
                    <td>Trigo (Tonelada)</td>
                    <td>R$ 1.250,00</td>
                    <td style="color: green; font-weight: bold;">Alta ▲</td>
                </tr>
            </tbody>
        </table>
    </section>

    <!-- NOVA SEÇÃO: SIMULADOR OPERACIONAL -->
    <section id="simulador" class="container" style="background-color: #e9f5ed;">
        <h2>Simulador de Produtividade</h2>
        <p>Preencha os dados da sua área para projetar os volumes da colheita.</p>
        
        <div class="simulador-box">
            <div class="campo-grupo">
                <label for="tipoCultura">Escolha o Cultivo:</label>
                <select id="tipoCultura">
                    <option value="soja">Soja (Média: 60 sacas/ha)</option>
                    <option value="milho">Milho (Média: 100 sacas/ha)</option>
                </select>
            </div>
            <div class="campo-grupo">
                <label for="campoHectares">Área de Plantio (Hectares):</label>
                <input type="number" id="campoHectares" placeholder="Ex: 50" min="1">
            </div>
            <!-- Chamei a função JavaScript inline usando onclick para eliminar falhas de escopo -->
            <button class="btn" style="width: 100%;" onclick="executarCalculoSafra()">Calcular Safra</button>
            
            <div id="blocoResultado" class="resultado-painel"></div>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 AgroTech. Todos os direitos reservados.</p>
    </footer>

    <!-- O BOTÃO FLUTUANTE -->
