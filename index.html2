            color: #999;
            font-size: 1.5rem;
            margin-left: 15px;
            transition: color 0.3s;
        }

        .sociais a:hover {
            color: var(--primary-light);
        }

        /* Responsividade Mobile */
        @media (max-width: 768px) {
            .nav-links {
                display: none;
                flex-direction: column;
                width: 100%;
                position: absolute;
                top: 70px;
                left: 0;
                background-color: var(--white);
                box-shadow: 0 10px 10px rgba(0,0,0,0.1);
                padding: 20px;
            }
            
            .nav-links.active {
                display: flex;
            }

            .menu-toggle {
                display: block;
            }

            .hero-content h1 {
                font-size: 2.2rem;
            }
        }
    </style>
