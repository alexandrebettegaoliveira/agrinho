<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Sementes</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }
        .container {
            background-color: #ffffff;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            max-width: 400px;
            width: 100%;
        }
        h2 {
            color: #2e7d32;
            text-align: center;
            margin-top: 0;
        }
        .form-group {
            margin-bottom: 15px;
        }
        label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #333;
        }
        input {
            width: 100%;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 5px;
            box-sizing: border-box;
        }
        button {
            width: 100%;
            padding: 12px;
            background-color: #2e7d32;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            font-weight: bold;
        }
        button:hover {
            background-color: #1b5e20;
        }
        .resultado {
            margin-top: 20px;
            padding: 15px;
            background-color: #e8f5e9;
            border-left: 5px solid #2e7d32;
            border-radius: 5px;
            display: none;
        }
        .resultado p {
            margin: 5px 0;
            color: #1b5e20;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Calculadora de Sementes</h2>
    
    <div class="form-group">
        <label for="populacao">População Desejada (plantas/ha):</label>
        <input type="number" id="populacao" value="300000" placeholder="Ex: 300000">
    </div>
    
    <div class="form-group">
        <label for="espacamento">Espaçamento entre Linhas (metros):</label>
        <input type="number" id="espacamento" step="0.01" value="0.45" placeholder="Ex: 0.45">
    </div>
    
    <div class="form-group">
        <label for="pms">Peso de Mil Sementes - PMS (gramas):</label>
        <input type="number" id="pms" value="180" placeholder="Ex: 180">
    </div>
    
    <div class="form-group">
        <label for="germinacao">Poder Germinativo / Pureza (%):</label>
        <input type="number" id="germinacao" value="90" placeholder="Ex: 90">
    </div>
    
    <div class="form-group">
        <label for="area">Área Total do Plantio (hectares):</label>
        <input type="number" id="area" value="10" placeholder="Ex: 10">
    </div>
    
    <button onclick="calcularSementes()">Calcular Necessidade</button>
    
    <div class="resultado" id="blocoResultado">
        <p><strong>Sementes por metro linear:</strong> <span id="resMetros">0</span> sementes/m</p>
        <p><strong>Total de sementes necessárias:</strong> <span id="resTotalSementes">0</span> sementes</p>
        <p><strong>Gasto de sementes por hectare:</strong> <span id="resKgHa">0</span> kg/ha</p>
        <p><strong>Gasto total para a área:</strong> <span id="resTotalKg">0</span> kg</p>
    </div>
</div>

<script>
function calcularSementes() {
    // 1. Captura os valores digitados pelo usuário no DOM
    const populacao = parseFloat(document.getElementById('populacao').value);
    const espacamento = parseFloat(document.getElementById('espacamento').value);
    const pms = parseFloat(document.getElementById('pms').value);
    const germinacao = parseFloat(document.getElementById('germinacao').value) / 100;
    const area = parseFloat(document.getElementById('area').value);

    // Validação simples para evitar divisão por zero ou campos vazios
    if (!populacao || !espacamento || !pms || !germinacao || !area) {
        alert("Por favor, preencha todos os campos corretamente.");
        return;
    }

    // 2. Lógica dos Cálculos Agronômicos
    // Ajusta a população desejada com base no Valor Cultural (germinação/pureza)
    const sementesAjustadasHa = populacao / germinacao;

    // Calcula quantos metros lineares de sulco existem em 1 hectare (10.000 m²)
    const metrosLinearesPorHa = 10000 / espacamento;

    // Sementes necessárias por metro linear de sulco
    const sementesPorMetro = sementesAjustadasHa / metrosLinearesPorHa;

    // Total de sementes para a área inteira
    const totalSementesArea = sementesAjustadasHa * area;

    // Quilos de sementes por hectare (Regra de três usando o Peso de Mil Sementes)
    const kgPorHa = (sementesAjustadasHa * pms) / 1000000;

    // Quilos totais para cobrir toda a propriedade
    const kgTotalArea = kgPorHa * area;

    // 3. Exibe os resultados formatados na tela
    document.getElementById('resMetros').innerText = sementesPorMetro.toFixed(2);
    document.getElementById('resTotalSementes').innerText = Math.round(totalSementesArea).toLocaleString('pt-BR');
    document.getElementById('resKgHa').innerText = kgPorHa.toFixed(2);
    document.getElementById('resTotalKg').innerText = kgTotalArea.toFixed(2);

    // Torna o bloco de resultados visível
    document.getElementById('blocoResultado').style.display = 'block';
}
</script>

</body>
</html>
